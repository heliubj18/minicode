<view class="search-page">
  <!-- 搜索栏 -->
  <view class="search-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="search-bar">
      <input
        class="search-input"
        placeholder="搜索目的地"
        value="{{keyword}}"
        bindinput="onInput"
        focus="{{true}}"
        confirm-type="search"
      />
      <text class="cancel-btn" bindtap="onCancel">取消</text>
    </view>
  </view>

  <scroll-view class="result-area" scroll-y type="list">
    <!-- 搜索结果 -->
    <view wx:if="{{results.length > 0}}" class="result-list">
      <view
        class="result-item"
        wx:for="{{results}}"
        wx:key="name"
        data-name="{{item.name}}"
        data-lat="{{item.lat}}"
        data-lng="{{item.lng}}"
        bindtap="onSelectResult"
      >
        <view class="result-icon">📍</view>
        <view class="result-info">
          <text class="result-name">{{item.name}}</text>
          <text class="result-addr">{{item.address}}</text>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view wx:elif="{{searching}}" class="loading-tip">
      <text>搜索中...</text>
    </view>

    <!-- 无关键词时显示历史 -->
    <view wx:elif="{{!keyword && history.length > 0}}" class="history-section">
      <text class="section-title">常用地点</text>
      <view
        class="history-item"
        wx:for="{{history}}"
        wx:key="*this"
        data-keyword="{{item}}"
        bindtap="onSelectHistory"
      >
        <text class="history-icon">🕐</text>
        <text class="history-text">{{item}}</text>
      </view>
    </view>

    <!-- 无结果 -->
    <view wx:elif="{{keyword && results.length === 0 && !searching}}" class="empty-tip">
      <text>未找到相关地点</text>
    </view>
  </scroll-view>
</view>
